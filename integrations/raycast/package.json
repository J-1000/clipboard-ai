{
  "name": "clipboard-ai",
  "title": "Clipboard AI",
  "description": "Run clipboard-ai actions from Raycast through the local HTTP API.",
  "icon": "icon.png",
  "author": "J-1000",
  "platforms": ["macOS"],
  "categories": ["Productivity", "Developer Tools"],
  "license": "MIT",
  "commands": [
    {
      "name": "setup",
      "title": "Setup Clipboard AI",
      "description": "Show the local HTTP API setup required for this extension.",
      "mode": "view"
    },
    {
      "name": "summary",
      "title": "Summarize Clipboard",
      "description": "Summarize the current clipboard with clipboard-ai.",
      "mode": "view",
      "keywords": ["summary", "summarize"]
    },
    {
      "name": "explain",
      "title": "Explain Clipboard",
      "description": "Explain the current clipboard with clipboard-ai.",
      "mode": "view",
      "keywords": ["explain", "code"]
    }
  ],
  "preferences": [
    {
      "name": "baseUrl",
      "title": "HTTP API Base URL",
      "description": "Local clipboard-ai HTTP API address.",
      "type": "textfield",
      "required": true,
      "default": "http://127.0.0.1:9159"
    },
    {
      "name": "token",
      "title": "HTTP Auth Token",
      "description": "Value of settings.http_auth_token in ~/.clipboard-ai/config.toml.",
      "type": "password",
      "required": true
    }
  ],
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "dependencies": {
    "@raycast/api": "1.104.19",
    "@raycast/utils": "2.2.6"
  },
  "devDependencies": {
    "@raycast/eslint-config": "2.1.1",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "eslint": "9.17.0",
    "prettier": "3.4.2",
    "typescript": "5.7.2"
  }
}
